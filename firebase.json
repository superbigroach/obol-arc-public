{
  "functions": [
    { "source": "functions", "codebase": "obol", "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"] },
    { "source": "seller-fn", "codebase": "seller" }
  ],
  "hosting": {
    "public": "out",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [{"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate"}]
      },
      {
        "source": "/_next/static/**",
        "headers": [{"key": "Cache-Control", "value": "public, max-age=31536000, immutable"}]
      }
    ],
    "rewrites": [
      {"source": "/api/wallet", "function": "apiWallet", "region": "us-central1"},
      {"source": "/api/services", "function": "apiServices", "region": "us-central1"},
      {"source": "/api/ack", "function": "apiAck", "region": "us-central1"},
      {"source": "/api/register-service", "function": "registerService", "region": "us-central1"},
      {"source": "/api/pay-and-call", "function": "payAndCall", "region": "us-central1"},
      {"source": "/api/agent-balance", "function": "getAgentBalance", "region": "us-central1"},
      {"source": "/api/contact", "function": "contactForm", "region": "us-central1"},
      {"source": "/api/spend-limit", "function": "spendLimit", "region": "us-central1"},
      {"source": "/api/receipt", "function": "receipt", "region": "us-central1"},
      {"source": "/api/report", "function": "reportService", "region": "us-central1"},
      {"source": "/seller/**", "destination": "/seller/_/index.html"},
      {"source": "/service/**", "destination": "/service/_/index.html"}
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
